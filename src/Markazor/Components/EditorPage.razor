    private bool IsDraftPath(string path)
    {
        try
        {
            return ContentPathPolicy.NormalizeGitHubPath(path).StartsWith(MarkazorRepositoryPaths.DraftsRoot, StringComparison.Ordinal);
        }
        catch (ArgumentException)
        {
            return false;
        }
    }

    private static string CreateDraftMarkdown(string title, string slug, string kind)
    {
        string today = DateTimeOffset.UtcNow.ToString(
            "yyyy-MM-dd",
            System.Globalization.CultureInfo.InvariantCulture);

        string escapedTitle = title.Replace("\"", "\\\"", StringComparison.Ordinal);

        return string.Join(
            '\n',
            "---",
            $"slug: {slug}",
            $"title: \"{escapedTitle}\"",
            $"kind: {kind}",
            "summary: \"\"",
            $"publishedAt: {today}",
            "draft: true",
            "tags: []",
            "---",
            string.Empty,
            "Start writing.");
    }

    private void ResetNewDraftDefaults()
    {
        newDraftTitle = "New Draft";
        newDraftTimestamp = CreateDraftTimestamp(DateTimeOffset.Now);
        newDraftSlug = CreateDefaultDraftSlug(newDraftTitle, newDraftTimestamp);
        newDraftSlugFollowsTitle = true;
    }

    private static string CreateDraftTimestamp(DateTimeOffset timestamp)
    {
        return timestamp.ToString("yyyyMMdd-HHmmss", CultureInfo.InvariantCulture);
    }

    private static string CreateDefaultDraftSlug(string title, string timestamp)
    {
        string titleSlug = NormalizeSlug(title);

        return titleSlug + "-" + timestamp;
    }

    private string CreateDocumentDefaultSlug(string title)
    {
        return string.IsNullOrWhiteSpace(documentSlugTimestamp)
            ? NormalizeSlug(title)
            : CreateDefaultDraftSlug(title, documentSlugTimestamp);
    }

    private static string? TryGetGeneratedSlugTimestamp(string slug)
    {
        string normalizedSlug = NormalizeSlug(slug);
        if (normalizedSlug.Length < 17)
        {
            return null;
        }

        int timestampStart = normalizedSlug.Length - 15;
        if (timestampStart <= 0
            || normalizedSlug[timestampStart - 1] != '-'
            || normalizedSlug[timestampStart + 8] != '-')
        {
            return null;
        }

        for (int index = timestampStart; index < normalizedSlug.Length; index++)
        {
            if (index == timestampStart + 8)
            {
                continue;
            }

            if (!char.IsAsciiDigit(normalizedSlug[index]))
            {
                return null;
            }
        }

        return normalizedSlug[timestampStart..];
    }

    private static string CreateDraftPath(string slug)
    {
        return MarkazorRepositoryPaths.DraftsRoot + NormalizeSlug(slug) + ".md";
    }

    private static string GetArticleKindLabel(string kind)
    {
        return string.Equals(MarkazorArticleKind.Normalize(kind), MarkazorArticleKind.Note, StringComparison.Ordinal)
            ? "Note"
            : "Post";
    }

    private static string ParseDocumentKind(MarkazorEditorDocument document)
    {
        return MarkdownContent.ParseArticleMeta(document.Path, document.Markdown).Kind;
    }

    private static string NormalizeSlug(string value)
    {
        StringBuilder builder = new(value.Length);
        bool pendingDash = false;
        foreach (char character in value.Trim().ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(character))
            {
                if (pendingDash && builder.Length > 0)
                {
                    _ = builder.Append('-');
                }

                _ = builder.Append(character);
                pendingDash = false;
            }
            else if (character is ' ' or '_' or '-' or '/' or '\\' or '.')
            {
                pendingDash = true;
            }
        }

        return builder.Length == 0 ? "new-draft" : builder.ToString();
    }

    private static bool IsSameSlug(string value, string slug)
    {
        return string.Equals(NormalizeSlug(value), NormalizeSlug(slug), StringComparison.Ordinal);
    }

    private static string NormalizePathOrEmpty(string value)
    {
        try
        {
            return ContentPathPolicy.NormalizeGitHubPath(value);
        }
        catch (ArgumentException)
        {
            return string.Empty;
        }
    }

    private static string EnsureTrailingSlash(string value)
    {
        return value.EndsWith('/') ? value : value + "/";
    }

    private static string GetFileName(string path)
    {
        string normalizedPath;
        try
        {
            normalizedPath = ContentPathPolicy.NormalizeGitHubPath(path);
        }
        catch (ArgumentException)
        {
            return path;
        }

        string fileName = System.IO.Path.GetFileName(normalizedPath);

        return string.IsNullOrWhiteSpace(fileName) ? normalizedPath : fileName;
    }

    private string CreateAssetRepositoryPath(string fileName)
    {
        return MarkazorRepositoryPaths.AssetsRoot + fileName;
    }

    private static string CreateAssetMarkdownPath(string repositoryPath)
    {
        string normalizedPath = ContentPathPolicy.NormalizeGitHubPath(repositoryPath);

        return "../" + normalizedPath;
    }

    private static string CreateAssetWebPath(string repositoryPath)
    {
        string normalizedPath = ContentPathPolicy.NormalizeGitHubPath(repositoryPath);

        return "/" + normalizedPath;
    }

    private static string? GetImageExtension(IBrowserFile file)
    {
        string contentType = file.ContentType.Trim().ToLowerInvariant();
        string extension = Path.GetExtension(file.Name).Trim().ToLowerInvariant();

        return contentType switch
        {
            "image/png" => ".png",
            "image/jpeg" => extension == ".jpeg" ? ".jpeg" : ".jpg",
            "image/webp" => ".webp",
            "image/gif" => ".gif",
            _ => extension switch
            {
                ".png" => ".png",
                ".jpg" => ".jpg",
                ".jpeg" => ".jpeg",
                ".webp" => ".webp",
                ".gif" => ".gif",
                _ => null,
            },
        };
    }

    private static string NormalizeImageContentType(string contentType, string extension)
    {
        string normalizedContentType = contentType.Trim().ToLowerInvariant();

        return normalizedContentType switch
        {
            "image/png" or "image/jpeg" or "image/webp" or "image/gif" => normalizedContentType,
            _ => extension switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "application/octet-stream",
            },
        };
    }

    private static string EscapeMarkdownAltText(string value)
    {
        return value
            .Replace("\\", "\\\\", StringComparison.Ordinal)
            .Replace("[", "\\[", StringComparison.Ordinal)
            .Replace("]", "\\]", StringComparison.Ordinal)
            .Replace("\r", " ", StringComparison.Ordinal)
            .Replace("\n", " ", StringComparison.Ordinal);
    }

    private static int CountWords(string value)
    {
        int count = 0;
        bool inWord = false;

        foreach (char character in value)
        {
            if (char.IsWhiteSpace(character))
            {
                inWord = false;
            }
            else if (!inWord)
            {
                count++;
                inWord = true;
            }
        }

        return count;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await ClearAllPendingAssetsAsync().ConfigureAwait(false);
            if (assetModule is not null)
            {
                await assetModule.InvokeVoidAsync("revokeAllObjectUrls").ConfigureAwait(false);
                await assetModule.DisposeAsync().ConfigureAwait(false);
            }
        }
        catch (JSException)
        {
        }
    }

    private sealed class EditorMetadataState : IEquatable<EditorMetadataState>
    {
        public string Slug { get; set; } = string.Empty;

        public string Title { get; set; } = string.Empty;

        public string Kind { get; set; } = MarkazorArticleKind.Post;

        public string Summary { get; set; } = string.Empty;

        public DateTime PublishedAt { get; set; } = DateTimeOffset.UnixEpoch.UtcDateTime;

        public bool IsDraft { get; set; }

        public string Tags { get; set; } = string.Empty;

        public string Category { get; set; } = string.Empty;

        public IReadOnlyList<string> AdditionalFrontMatterLines { get; private init; } = [];

        public bool HasRequiredValues =>
            !string.IsNullOrWhiteSpace(Slug)
            && !string.IsNullOrWhiteSpace(Title);

        public static EditorMetadataState CreateDefault()
        {
            return new EditorMetadataState();
        }

        public static EditorMetadataState FromDocument(MarkdownDocument document)
        {
            ArgumentNullException.ThrowIfNull(document);

            MarkdownDocumentMetadata source = document.Metadata;

            return new EditorMetadataState
            {
                Slug = source.Slug,
                Title = source.Title,
                Kind = MarkazorArticleKind.Normalize(source.Kind),
                Summary = source.Summary,
                PublishedAt = source.PublishedAtUtc.UtcDateTime,
                IsDraft = source.IsDraft,
                Tags = string.Join(", ", source.Tags),
                Category = source.Category ?? string.Empty,
                AdditionalFrontMatterLines = [.. source.AdditionalFrontMatterLines],
            };
        }

        public EditorMetadataState Clone()
        {
            return new EditorMetadataState
            {
                Slug = Slug,
                Title = Title,
                Kind = Kind,
                Summary = Summary,
                PublishedAt = PublishedAt,
                IsDraft = IsDraft,
                Tags = Tags,
                Category = Category,
                AdditionalFrontMatterLines = [.. AdditionalFrontMatterLines],
            };
        }

        public MarkdownDocumentMetadata ToDocumentMetadata()
        {
            return new MarkdownDocumentMetadata(
                NormalizeRequiredText(Slug),
                NormalizeRequiredText(Title),
                MarkazorArticleKind.Normalize(Kind),
                NormalizeOptionalText(Summary) ?? string.Empty,
                ToPublishedAtUtc(),
                IsDraft,
                ParseTags(Tags),
                NormalizeOptionalText(Category),
                AdditionalFrontMatterLines);
        }

        public bool Equals(EditorMetadataState? other)
        {
            return other is not null
                && string.Equals(NormalizeRequiredText(Slug), NormalizeRequiredText(other.Slug), StringComparison.Ordinal)
                && string.Equals(NormalizeRequiredText(Title), NormalizeRequiredText(other.Title), StringComparison.Ordinal)
                && string.Equals(MarkazorArticleKind.Normalize(Kind), MarkazorArticleKind.Normalize(other.Kind), StringComparison.Ordinal)
                && string.Equals(NormalizeOptionalText(Summary), NormalizeOptionalText(other.Summary), StringComparison.Ordinal)
                && ToPublishedAtUtc().Equals(other.ToPublishedAtUtc())
                && IsDraft == other.IsDraft
                && ParseTags(Tags).SequenceEqual(ParseTags(other.Tags), StringComparer.Ordinal)
                && string.Equals(NormalizeOptionalText(Category), NormalizeOptionalText(other.Category), StringComparison.Ordinal)
                && AdditionalFrontMatterLines.SequenceEqual(other.AdditionalFrontMatterLines, StringComparer.Ordinal);
        }

        public override bool Equals(object? obj)
        {
            return obj is EditorMetadataState other && Equals(other);
        }

        public override int GetHashCode()
        {
            HashCode hash = new();
            hash.Add(NormalizeRequiredText(Slug), StringComparer.Ordinal);
            hash.Add(NormalizeRequiredText(Title), StringComparer.Ordinal);
            hash.Add(MarkazorArticleKind.Normalize(Kind), StringComparer.Ordinal);
            hash.Add(NormalizeOptionalText(Summary), StringComparer.Ordinal);
            hash.Add(ToPublishedAtUtc());
            hash.Add(IsDraft);
            foreach (string tag in ParseTags(Tags))
            {
                hash.Add(tag, StringComparer.Ordinal);
            }

            hash.Add(NormalizeOptionalText(Category), StringComparer.Ordinal);
            foreach (string line in AdditionalFrontMatterLines)
            {
                hash.Add(line, StringComparer.Ordinal);
            }

            return hash.ToHashCode();
        }

        private DateTimeOffset ToPublishedAtUtc()
        {
            DateTime utcValue = DateTime.SpecifyKind(PublishedAt, DateTimeKind.Utc);

            return new DateTimeOffset(utcValue);
        }

        private static string NormalizeRequiredText(string value)
        {
            return value.Trim();
        }

        private static string? NormalizeOptionalText(string? value)
        {
            string? normalized = value?.Trim();

            return string.IsNullOrWhiteSpace(normalized) ? null : normalized;
        }

        private static string[] ParseTags(string value)
        {
            return
            [
                .. value.Split([','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Select(static tag => tag.Trim('"', '\''))
                    .Where(static tag => tag.Length > 0),
            ];
        }
    }

    private sealed record PendingEditorAsset(
        string RepositoryPath,
        string MarkdownPath,
        string WebPath,
        string ContentType,
        byte[] Content,
        string? PreviewUrl,
        bool RequiresUpload);
}
