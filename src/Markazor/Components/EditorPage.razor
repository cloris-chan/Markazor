    private async Task InsertExternalImageAsync()
    {
        string altText = string.IsNullOrWhiteSpace(metadata.Title) ? "image" : metadata.Title.Trim();
        await InsertMarkdownAsync($"![{EscapeMarkdownAltText(altText)}](https://)").ConfigureAwait(false);
    }

    private async Task UploadImageAsync(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
        {
            return;
        }

        IBrowserFile file = args.File;
        string? extension = GetImageExtension(file);
        if (extension is null)
        {
            SetError("Only PNG, JPEG, WebP, and GIF images can be uploaded.");

            return;
        }

        if (file.Size > MaxImageAssetBytes)
        {
            SetError("Image uploads are limited to 8 MB.");

            return;
        }

        byte[] content = new byte[file.Size];
        await using Stream stream = file.OpenReadStream(MaxImageAssetBytes);
        int offset = 0;
        while (offset < content.Length)
        {
            int read = await stream.ReadAsync(content.AsMemory(offset), CancellationToken.None).ConfigureAwait(false);
            if (read == 0)
            {
                break;
            }

            offset += read;
        }

        if (offset != content.Length)
        {
            Array.Resize(ref content, offset);
        }

        string hash = Convert.ToHexString(SHA256.HashData(content)).ToLowerInvariant();
        string fileName = hash + extension;
        string repositoryPath = CreateAssetRepositoryPath(fileName);
        string markdownPath = CreateAssetMarkdownPath(repositoryPath);
        string webPath = CreateAssetWebPath(repositoryPath);
        string contentType = NormalizeImageContentType(file.ContentType, extension);
        IJSObjectReference? module = await EnsureAssetModuleAsync().ConfigureAwait(false);
        string? previewUrl = module is null
            ? null
            : await module.InvokeAsync<string>(
                "createObjectUrl",
                webPath,
                contentType,
                content).ConfigureAwait(false);

        pendingAssets[markdownPath] = new PendingEditorAsset(
            repositoryPath,
            markdownPath,
            webPath,
            contentType,
            content,
            previewUrl,
            RequiresUpload: true);

        string altText = string.IsNullOrWhiteSpace(Path.GetFileNameWithoutExtension(file.Name))
            ? "image"
            : Path.GetFileNameWithoutExtension(file.Name);
        await InsertMarkdownAsync($"![{EscapeMarkdownAltText(altText)}]({markdownPath})").ConfigureAwait(false);
        SetSuccess($"Image ready: {fileName}");
    }

    private async Task InsertMarkdownAsync(string markdown)
    {
        if (markdownEditor is not null)
        {
            await markdownEditor.InsertMarkdownAsync(markdown).ConfigureAwait(false);

            return;
        }

        bodyMarkdown += markdown;
    }

    private string RenderPreviewHtml()
    {
        string html = MarkdownRenderer.ToSafeHtml(bodyMarkdown);

        foreach (PendingEditorAsset asset in GetReferencedPendingAssets())
        {
            if (string.IsNullOrWhiteSpace(asset.PreviewUrl))
            {
                continue;
            }

            string encodedMarkdownPath = HtmlEncoder.Default.Encode(asset.MarkdownPath);
            string encodedPreviewUrl = HtmlEncoder.Default.Encode(asset.PreviewUrl);
            html = html.Replace(
                $"src=\"{encodedMarkdownPath}\"",
                $"src=\"{encodedPreviewUrl}\"",
                StringComparison.Ordinal);
            html = html.Replace(
                $"href=\"{encodedMarkdownPath}\"",
                $"href=\"{encodedPreviewUrl}\"",
                StringComparison.Ordinal);
        }

        return html;
    }

    private IReadOnlyList<PendingEditorAsset> GetReferencedPendingAssets()
    {
        return
        [
            .. pendingAssets.Values
                .Where(asset => bodyMarkdown.Contains(asset.MarkdownPath, StringComparison.Ordinal))
                .OrderBy(static asset => asset.MarkdownPath, StringComparer.Ordinal),
        ];
    }

    private IReadOnlyList<MarkazorEditorAsset> GetReferencedPendingEditorAssets()
    {
        return
        [
            .. GetReferencedPendingAssets()
                .Where(static asset => asset.RequiresUpload)
                .Select(static asset => new MarkazorEditorAsset(
                    asset.RepositoryPath,
                    asset.MarkdownPath,
                    asset.ContentType,
                    asset.Content)),
        ];
    }

    private void MarkReferencedPendingAssetsUploaded()
    {
        string[] keys =
        [
            .. pendingAssets
                .Where(pair => bodyMarkdown.Contains(pair.Value.MarkdownPath, StringComparison.Ordinal))
                .Select(static pair => pair.Key),
        ];

        foreach (string key in keys)
        {
            if (pendingAssets.TryGetValue(key, out PendingEditorAsset? asset))
            {
                pendingAssets[key] = asset with { RequiresUpload = false };
            }
        }
    }

    private async Task ClearAllPendingAssetsAsync()
    {
        foreach (string key in pendingAssets.Keys.ToArray())
        {
            await RevokePendingAssetAsync(key).ConfigureAwait(false);
        }
    }

    private async Task RevokePendingAssetAsync(string key)
    {
        if (!pendingAssets.Remove(key, out PendingEditorAsset? asset)
            || string.IsNullOrWhiteSpace(asset.PreviewUrl))
        {
            return;
        }

        IJSObjectReference? module = await EnsureAssetModuleAsync().ConfigureAwait(false);
        if (module is not null)
        {
            await module.InvokeVoidAsync("revokeObjectUrl", key).ConfigureAwait(false);
        }
    }

    private async Task<IJSObjectReference?> EnsureAssetModuleAsync()
    {
        if (assetModule is not null)
        {
            return assetModule;
        }

        try
        {
            assetModule = await JavaScript.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/Markazor/markazor-editor-assets.js").ConfigureAwait(false);

            return assetModule;
        }
        catch (InvalidOperationException)
        {
            return null;
        }
        catch (JSException)
        {
            return null;
        }
    }

    private async Task<IReadOnlyList<MarkazorContentEntry>> RefreshEditorCatalogAsync()
    {
        IReadOnlyList<MarkazorContentEntry> entries = await Catalog.RefreshAsync().ConfigureAwait(false);
        PruneDraftSelection();

        return entries;
    }

    private void PruneDraftSelection()
    {
        selectedDraftPaths.RemoveWhere(path => !Catalog.Entries.Any(entry =>
            entry.ExistsOnGitHub
            && entry.IsDraft
            && string.Equals(entry.RelativePath, path, StringComparison.Ordinal)));
    }

